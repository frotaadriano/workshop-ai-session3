# Variáveis de ambiente necessárias para rodar a aplicação
# Copie este arquivo para .env e preencha com suas credenciais do Azure
# NUNCA versione o arquivo .env

# Endpoint do seu recurso Azure Document Intelligence
# Exemplo: https://meu-recurso.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=

# Chave de API do seu recurso Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_KEY=
