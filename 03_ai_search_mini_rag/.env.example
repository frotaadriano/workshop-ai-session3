# Variáveis de ambiente — AI Search + Mini RAG
# Copie este arquivo para .env e preencha com seus dados reais

# -------------------------------------------------------
# Azure AI Search
# -------------------------------------------------------

# URL do seu serviço de busca (ex: https://meu-servico.search.windows.net)
AZURE_SEARCH_ENDPOINT=https://SEU_SERVICO.search.windows.net

# Chave de administrador ou de consulta do Azure AI Search
AZURE_SEARCH_KEY=SUA_CHAVE_DO_SEARCH

# Nome do índice que contém os documentos
AZURE_SEARCH_INDEX_NAME=nome-do-seu-indice

# Campos do índice a retornar (ajuste conforme os campos do seu índice)
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_TITLE_FIELD=title

# -------------------------------------------------------
# Azure OpenAI
# -------------------------------------------------------

# Chave de API do Azure OpenAI
AZURE_OPENAI_API_KEY=SUA_CHAVE_DO_OPENAI

# URL do endpoint do Azure OpenAI (ex: https://meu-recurso.openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://SEU_RECURSO.openai.azure.com

# Versão da API (recomendado: 2024-02-15-preview ou mais recente)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Nome do deployment do modelo de chat (ex: gpt-4o, gpt-35-turbo)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
